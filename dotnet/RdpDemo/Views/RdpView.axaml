<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RdpDemo.ViewModels"
             x:Class="RdpDemo.Views.RdpView"
             x:DataType="vm:MainWindowViewModel"
             Focusable="True"
             Background="#111111">
    <Grid RowDefinitions="*,Auto">
        <!-- Framebuffer -->
        <Border Grid.Row="0" ClipToBounds="True" Background="#111111">
            <Image x:Name="FramebufferImage"
                   Source="{Binding Framebuffer}"
                   Stretch="Uniform"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Stretch"
                   Focusable="True"
                   PointerMoved="OnPointerMoved"
                   PointerPressed="OnPointerPressed"
                   PointerReleased="OnPointerReleased"
                   PointerWheelChanged="OnPointerWheelChanged"/>
        </Border>

        <!-- Status bar -->
        <Border Grid.Row="1"
                Padding="8,4"
                Background="#1E1E1E"
                BorderBrush="#333333"
                BorderThickness="0,1,0,0">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="{Binding ScaleModeText}"
                        Command="{Binding ToggleScaleModeCommand}"
                        Padding="10,2"
                        Margin="0,0,4,0"
                        FontSize="11"
                        Background="Transparent"
                        Foreground="#AAAAAA"
                        BorderThickness="1"
                        BorderBrush="#444444"/>
                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusText}" Foreground="#CCCCCC" FontSize="12"/>
                    <TextBlock Foreground="#888888" FontSize="12">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0}×{1}">
                                <Binding Path="RemoteWidth"/>
                                <Binding Path="RemoteHeight"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
